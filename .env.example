# Database Configuration
DB_NAME=smart_meter_db
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_HOST=localhost
DB_PORT=5432

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# Django Configuration
SECRET_KEY=django-insecure-change-this-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Django Tasks Backend (using django-tasks package)
# Options:
#   django_tasks.backends.database.DatabaseBackend (async - requires db_worker)
#   django_tasks.backends.immediate.ImmediateBackend (sync - for quick testing)
#   django_tasks.backends.dummy.DummyBackend (testing - no execution)
# Run worker with: python manage.py db_worker
DJANGO_TASKS_BACKEND=django_tasks.backends.database.DatabaseBackend

# Celery Configuration
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
CELERY_TIMEZONE=Asia/Tokyo

# Flower Configuration (Celery monitoring)
# Run with: celery -A config flower --port=5555
FLOWER_PORT=5555
FLOWER_BASIC_AUTH=admin:password
